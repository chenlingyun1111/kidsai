# Database
KIDSAI_DATABASE_URL=postgresql+asyncpg://kidsai:kidsai@localhost:5432/kidsai
KIDSAI_REDIS_URL=redis://localhost:6379/0

# Auth
KIDSAI_JWT_SECRET=change-me-to-a-random-string

# Object Storage
KIDSAI_MINIO_ENDPOINT=localhost:9000
KIDSAI_MINIO_ACCESS_KEY=minioadmin
KIDSAI_MINIO_SECRET_KEY=minioadmin
KIDSAI_MINIO_BUCKET=kidsai

# AI Providers - fill in the ones you use
KIDSAI_DEEPSEEK_API_KEY=your-deepseek-api-key
KIDSAI_DEEPSEEK_MODEL=deepseek-chat
KIDSAI_DASHSCOPE_API_KEY=your-dashscope-api-key
KIDSAI_VOLCANO_ACCESS_KEY=your-volcano-access-key
KIDSAI_VOLCANO_SECRET_KEY=your-volcano-secret-key
KIDSAI_CLAUDE_API_KEY=your-claude-api-key

# Provider selection: deepseek | claude | qwen
KIDSAI_LLM_PROVIDER=deepseek
# Provider selection: volcano | whisper
KIDSAI_STT_PROVIDER=volcano
# Provider selection: volcano | edge
KIDSAI_TTS_PROVIDER=edge
